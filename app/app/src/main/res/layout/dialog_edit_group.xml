<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Group"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Group name"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etEditGroupName"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"
        android:inputType="textCapWords"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add member by username"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/etEditMemberUsername"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:hint="Username"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:inputType="textCapWords"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditAddMember"
            android:layout_width="wrap_content"
            android:layout_height="54dp"
            android:text="Add"
            android:textColor="@color/bg_primary"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current members (tap to remove)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipEditMembers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:chipSpacingHorizontal="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveGroup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save Changes"
        android:textColor="@color/bg_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="@color/accent"
        app:cornerRadius="16dp"/>

    <TextView
        android:id="@+id/tvEditStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:layout_gravity="center"/>
</LinearLayout>