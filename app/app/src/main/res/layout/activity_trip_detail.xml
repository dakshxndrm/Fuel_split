<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Header row: Back + title + status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.App.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="← Back"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Trip"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/tvDetailBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_paidby_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginEnd="8dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_subtle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stat boxes row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvDetailTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="@color/money_positive"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="total cost"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvDetailDist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_box"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDetailFuel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="litres"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Paid by -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAID BY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailPaidBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:layout_marginBottom="20dp"/>

            <!-- Cost split -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COST SPLIT"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/sharesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <!-- On-chain group (hidden by default) -->
            <TextView
                android:id="@+id/tvGroupAddressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON-CHAIN GROUP"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvGroupAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"/>

            <!-- Settle status -->
            <TextView
                android:id="@+id/tvSettleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>
        </LinearLayout>
    </ScrollView>

    <!-- Settle button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettle"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Settle This Trip"/>
    </LinearLayout>
</LinearLayout>
