<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════
         CARDS
    ══════════════════════════════════════════ -->

    <!-- Base card: rounded corners, subtle stroke, no elevation shadow -->
    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">@color/border_normal</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="rippleColor">@color/accent_soft</item>
        <item name="android:layout_marginBottom">@dimen/card_margin_bottom</item>
    </style>

    <!-- Elevated card (for dialogs / summary panels) -->
    <style name="Widget.App.CardView.Elevated" parent="Widget.App.CardView">
        <item name="cardBackgroundColor">@color/bg_card_elevated</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         BUTTONS
    ══════════════════════════════════════════ -->

    <!-- Primary filled button (confirm, submit, settle) -->
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
    </style>

    <!-- Outlined button (secondary actions) -->
    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height_small</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/accent_soft</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
    </style>

    <!-- Destructive outlined button (delete) -->
    <style name="Widget.App.Button.Outlined.Danger" parent="Widget.App.Button.Outlined">
        <item name="android:textColor">@color/money_negative</item>
        <item name="strokeColor">@color/money_negative</item>
        <item name="backgroundTint">@color/pending_bg</item>
    </style>

    <!-- Text-only button (back, cancel) -->
    <style name="Widget.App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
    </style>

    <!-- ══════════════════════════════════════════
         BOTTOM NAVIGATION
    ══════════════════════════════════════════ -->

    <style name="Widget.App.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/nav_bg</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         EXTENDED FAB
    ══════════════════════════════════════════ -->

    <style name="Widget.App.ExtendedFAB" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="iconTint">@color/text_on_accent</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         CHIPS
    ══════════════════════════════════════════ -->

    <style name="Widget.App.Chip.Status" parent="Widget.Material3.Chip.Assist">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="chipMinHeight">28dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipIconVisible">false</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <!-- Settled chip -->
    <style name="Widget.App.Chip.Settled" parent="Widget.App.Chip.Status">
        <item name="android:textColor">@color/settled_text</item>
        <item name="chipBackgroundColor">@color/settled_bg</item>
        <item name="chipStrokeColor">@color/settled_text</item>
    </style>

    <!-- Pending chip -->
    <style name="Widget.App.Chip.Pending" parent="Widget.App.Chip.Status">
        <item name="android:textColor">@color/pending_text</item>
        <item name="chipBackgroundColor">@color/pending_bg</item>
        <item name="chipStrokeColor">@color/pending_text</item>
    </style>

    <!-- ══════════════════════════════════════════
         TEXT APPEARANCES (M3 type scale)
    ══════════════════════════════════════════ -->

    <style name="TextAppearance.App.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.App.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.TitleSmall" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.App.BodySmall" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.App.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Money amounts -->
    <style name="TextAppearance.App.Money.Positive" parent="TextAppearance.App.Title">
        <item name="android:textColor">@color/money_positive</item>
    </style>

    <style name="TextAppearance.App.Money.Negative" parent="TextAppearance.App.Title">
        <item name="android:textColor">@color/money_negative</item>
    </style>

    <!-- ══════════════════════════════════════════
         SECTION LABELS
    ══════════════════════════════════════════ -->

    <style name="Widget.App.SectionLabel" parent="android:Widget">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginTop">@dimen/spacing_20</item>
        <item name="android:layout_marginBottom">@dimen/spacing_8</item>
    </style>

</resources>
