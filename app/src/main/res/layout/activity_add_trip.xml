<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootAddTrip"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvStepLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Who was there?"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Step Progress Bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/stepProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:progress="33"
        android:max="100"
        app:indicatorColor="@color/accent"
        app:trackColor="@color/border_normal"
        app:trackCornerRadius="4dp"
        app:trackThickness="6dp"/>

    <!-- Step Content -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:measureAllChildren="false">

        <!-- STEP 1 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etTripName"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="e.g. Weekend trip to Pushkar"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="24dp"/>

                <!-- Selectable list: contacts + group members -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PEOPLE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/contactsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp"/>

                <!-- Friend-code input for new people -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OR ADD BY FRIEND CODE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/etNewPersonName"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:hint="Friend code"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input"
                        android:inputType="text"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddPerson"
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:text="Add"
                        android:textColor="@color/bg_primary"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="14dp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/dynamicChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"/>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 2 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Trip name — only shown when launched from a group (preload mode) -->
                <TextView
                    android:id="@+id/tvTripNamePreloadLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <EditText
                    android:id="@+id/etTripNamePreload"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="e.g. Weekend trip to Pushkar"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Distance (km)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etDistance"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="e.g.  135"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bike Mileage (km per litre)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etMileage"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="e.g.  40"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuel Price (₹ per litre)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etFuelPrice"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="e.g.  110"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"/>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 3 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Who paid for the fuel?"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerPaidBy"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:id="@+id/percentageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </ScrollView>
    </ViewFlipper>

    <!-- Bottom: Next / Submit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Next  →"
            android:textColor="@color/bg_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>
    </LinearLayout>
</LinearLayout>