<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvStepLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Who was there?"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Step Progress Bar ── -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/stepProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progress="33"
        android:max="100"
        app:indicatorColor="@color/accent"
        app:trackColor="@color/border_normal"
        app:trackCornerRadius="4dp"
        app:trackThickness="4dp"/>

    <!-- ── Step Content ── -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:measureAllChildren="false">

        <!-- STEP 1: Trip name + members -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Trip Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etTripName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. Weekend trip to Pushkar"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="24dp"/>

                <!-- Members Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Members"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etNewPersonName"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:hint="Enter name"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input"
                        android:inputType="textCapWords"/>

                    <Button
                        android:id="@+id/btnAddPerson"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:text="Add"
                        android:textColor="@color/bg_primary"
                        android:textStyle="bold"
                        android:backgroundTint="@color/accent"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/dynamicChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"/>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 2: Trip details -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Distance (km)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etDistance"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g.  135"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bike Mileage (km per litre)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etMileage"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g.  40"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuel Price (₹ per litre)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etFuelPrice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g.  110"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input"
                    android:inputType="numberDecimal"/>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 3: Who paid + split percentages -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Who paid for the fuel?"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerPaidBy"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Percentage rows populated from Java -->
                <LinearLayout
                    android:id="@+id/percentageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </ScrollView>
    </ViewFlipper>

    <!-- ── Bottom: Next / Submit Button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Next  →"
            android:textColor="@color/bg_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:textAllCaps="false"/>
    </LinearLayout>
</LinearLayout>