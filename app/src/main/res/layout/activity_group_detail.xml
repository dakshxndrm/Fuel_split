<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/groupDetailHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailGroupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Group Name"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDetailMemberCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 members"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditGroup"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Edit"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:backgroundTint="@color/accent_soft"
            app:cornerRadius="10dp"
            app:strokeColor="@color/accent"
            app:strokeWidth="1dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_subtle"/>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="100dp">

            <!-- Members section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Members"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/membersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Balances section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Balances"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/balancesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Expenses section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/expensesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tvNoExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No expenses yet"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_primary"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExpense"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="+ Add Expense"
            android:textColor="@color/bg_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/accent"
            app:cornerRadius="14dp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Settle Up"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/accent_soft"
            app:cornerRadius="14dp"
            app:strokeColor="@color/accent"
            app:strokeWidth="1dp"/>
    </LinearLayout>
</LinearLayout>